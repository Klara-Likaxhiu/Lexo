# Copy this file to .env and fill in your values.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Supabase (Auth + Postgres — single source of truth) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL of your app (used in Supabase email redirect links)
# Production (Render):
APP_BASE_URL=https://lexo-0a6u.onrender.com

# Optional: admin key for manual book cover overrides (X-Cover-Admin-Key header)
BOOKMIND_COVER_ADMIN_KEY=

# Email verification (Supabase sends confirmation emails when enabled)
EMAIL_VERIFICATION_REQUIRED=true

# ── Social Sign-In (also enable providers in Supabase Auth dashboard) ─────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Supabase Dashboard checklist:
# 1. Authentication → Providers → Email: enable, confirm email ON
# 2. Authentication → URL Configuration:
#    Site URL: https://lexo-0a6u.onrender.com
#    Redirect URLs: https://lexo-0a6u.onrender.com/verify-email.html
#                     https://lexo-0a6u.onrender.com/reset-password.html
# 3. (Recommended) Confirm signup email template — use token_hash so verify-email.html works:
#    <a href="{{ .RedirectTo }}?token_hash={{ .TokenHash }}&type=email">Confirm your email</a>
#    Or keep default {{ .ConfirmationURL }} (Supabase redirects with access_token in URL hash).
# 4. SQL Editor: run supabase/schema.sql
