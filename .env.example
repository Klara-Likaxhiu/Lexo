# Copy this file to .env and fill in your values.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Supabase (Auth + email) ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Required for My Library, account deletion (Dashboard → Settings → API → service_role)
# Also run supabase/schema.sql in the Supabase SQL editor.
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of your app (used in Supabase email redirect links)
APP_BASE_URL=http://127.0.0.1:8000

# When using Supabase, email verification defaults to ON (Supabase sends emails).
# Set to false only if you disabled "Confirm email" in Supabase Auth settings.
EMAIL_VERIFICATION_REQUIRED=true

# Legacy JWT secret — not used when Supabase Auth is configured.
JWT_SECRET=

# ── Social Sign-In (also enable providers in Supabase Auth dashboard) ─────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# ── Legacy SMTP (optional fallback if Supabase is not configured) ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=BookMindAI <noreply@bookmind.ai>
SMTP_USE_TLS=true
SMTP_USE_SSL=false
